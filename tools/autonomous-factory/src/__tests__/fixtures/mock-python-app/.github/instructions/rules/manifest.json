{
  "app": {
    "name": "mock-python-service",
    "description": "A mock Python microservice for testing multi-app support"
  },
  "urls": {
    "functionApp": "https://mock-python-svc.azurewebsites.net"
  },
  "directories": {
    "backend": "src",
    "frontend": null,
    "infra": "infra",
    "e2e": null,
    "packages": null
  },
  "testCommands": {
    "backendUnit": "cd {appRoot} && pytest -v",
    "frontendUnit": null,
    "integration": "cd {appRoot} && pytest tests/integration -v"
  },
  "commitScopes": {
    "backend": ["src/", "infra/", "in-progress/"]
  },
  "personas": {
    "backend-dev": { "include": ["always"] },
    "backend-unit-test": { "include": ["always"] },
    "push-code": { "include": ["always"] },
    "poll-ci": { "include": ["always"] },
    "integration-test": { "include": ["always"] },
    "create-pr": { "include": ["always"] }
  },
  "tokenBudget": 4500
}
