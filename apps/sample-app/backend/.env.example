# Demo Auth Configuration
# See docs/adr/001-demo-auth-mode.md for details

# Auth mode: "demo" (shared credentials) or "entra" (Entra ID / MSAL)
AUTH_MODE=demo

# Demo credentials (only used when AUTH_MODE=demo)
DEMO_USER=demo
DEMO_PASS=demopass

# Demo token — any UUID. In production, generated by Terraform (random_uuid)
# and stored in Key Vault. For local dev, any UUID works.
DEMO_TOKEN=00000000-0000-0000-0000-000000000001
