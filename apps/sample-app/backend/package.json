{
  "name": "sample-app-backend",
  "version": "0.1.0",
  "type": "module",
  "description": "Azure Functions backend for sample-app — demo auth + your API",
  "main": "dist/src/functions/*.js",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "rm -rf dist && node esbuild.config.mjs",
    "build:typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prestart": "npm run clean && npm run build",
    "start": "func start",
    "lint": "tsc --noEmit",
    "test": "jest --verbose",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:integration": "RUN_INTEGRATION=true jest --testPathPatterns=integration --verbose",
    "validate:schemas": "cd ../packages/schemas && npx jest --verbose"
  },
  "dependencies": {
    "@azure/functions": "^4.7.0",
    "@branded/schemas": "0.1.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^22.0.0",
    "esbuild": "^0.27.4",
    "jest": "^30.0.0",
    "ts-jest": "^29.3.0",
    "typescript": "^5.8.0"
  }
}
