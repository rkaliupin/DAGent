# =============================================================================
# Root .gitignore — Agentic Pipeline Platform
# =============================================================================

# ----- OS -----
.DS_Store
Thumbs.db

# ----- Editors / IDEs -----
.vscode/
!.vscode/settings.json
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~

# ----- Terraform -----
**/.terraform/
.terraform.lock.hcl
*.tfstate
*.tfstate.backup
*.tfstate.*.backup
*.tfplan
tfplan
*.auto.tfvars
*.tfvars
!example.tfvars
!dev.tfvars
crash.log
crash.*.log

# ----- Node / Next.js -----
node_modules/
.next/
out/
dist/
build/
packages/*/dist/
*.tsbuildinfo
.env
.env.*
!.env.example

# ----- Python -----
__pycache__/
*.pyc
.venv/
venv/

# ----- Roam (semantic graph index) -----
.roam/

# ----- APM compiled output -----
.apm/.compiled/

# ----- Logs -----
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
# ----- Pipeline temp files -----
PR_BODY.md
in-progress/*.mjs
in-progress/*.js
in-progress/*.ts
!in-progress/README.md
# ----- Playwright -----
test-results/
playwright-report/
blob-report/

# ----- Misc -----
.cache/
tmp/
coverage/
deploy/
